rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true
        || (
          request.auth.token.get('email', null) != null
          && exists(/databases/$(database)/documents/admin_role_users/$(request.auth.token.email.lower()))
          && get(/databases/$(database)/documents/admin_role_users/$(request.auth.token.email.lower())).data.isActive == true
        )
      );
    }

    function _isAdminWriteAllowed() {
      return isAdmin();
    }

    function _authEmail() {
      return isAuthenticated() && request.auth.token.get('email', null) != null
        ? request.auth.token.email.lower()
        : null;
    }

    function _isPrimaryAdmin() {
      return isAdmin() && _authEmail() != null && (
        _authEmail() == 'admin@goldencares.in'
        || (
          exists(/databases/$(database)/documents/admin_role_users/$(_authEmail()))
          && get(/databases/$(database)/documents/admin_role_users/$(_authEmail())).data.isActive == true
          && get(/databases/$(database)/documents/admin_role_users/$(_authEmail())).data.adminType == 'primary'
        )
      );
    }

    // --- Rules for Collections ---

    // Users: Owners and Admins can read/write
    // SECURITY FIX: Prevent privilege escalation — users cannot self-assign 'admin' role
    match /users/{userId} {
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role in ['family', 'caregiver']
        && request.resource.data.role != 'admin';
      allow read: if isOwner(userId)
        || isAdmin()
        || (isAuthenticated() && getUserData().role == 'caregiver');
      // Users may update their own profile, including emergencyContacts,
      // but cannot change their role.
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;
      allow update: if _isAdminWriteAllowed();
      allow delete: if isVerified() && (isOwner(userId) || isAdmin());
    }

    // Bookings: Owners, assigned Personnel, Admins, and authenticated family
    // users (family read access required to compute slot availability counts)
    match /bookings/{bookingId} {
      // Allow authenticated owners, assigned caregivers, admins, and family users to read.
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.userId
          || request.auth.uid == resource.data.servicePersonnelId
          || request.auth.uid == resource.data.caregiverId
          || _isAdminWriteAllowed()
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'family'
        );

  // Families may create a pending-payment booking before checkout.
      // Using get() instead of getUserData() helper so we can check role without
      // requiring email_verified (isVerified), which blocks unverified test users.
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'family'
        && request.resource.data.paymentStatus == 'pending_payment'
        && request.resource.data.userId == request.auth.uid;

      // Family owner may assign a caregiver from client-side booking flow.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'servicePersonnelId',
          'servicePersonnelName',
          'updatedAt'
        ]);

      // Family owner may only perform cancellation-style updates from client.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelledBy',
          'updatedAt'
        ]);

      // Assigned caregiver or admin may perform operational updates.
      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.servicePersonnelId
          || request.auth.uid == resource.data.caregiverId
          || _isAdminWriteAllowed()
        )
        && request.resource.data.status != 'expired'
        && request.resource.data.paymentStatus != 'expired';

      // Only the booking owner or admin may delete a booking.
      allow delete: if isVerified()
        && (request.auth.uid == resource.data.userId || isAdmin());
    }

  // Service Personnel: Everyone can read, Personnel and Admins can write
    // SECURITY FIX: Enforce personnelId == auth.uid on create to prevent impersonation
    match /servicePersonnel/{personnelId} {
        // Public caregiver discovery is supported from landing and family flows.
        allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == personnelId;
      allow update: if isOwner(personnelId) || _isAdminWriteAllowed();
      allow delete: if isVerified() && (isOwner(personnelId) || _isAdminWriteAllowed());
    }

    // Services: Publicly readable, Admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if _isAdminWriteAllowed();
    }

    // Config: Authenticated read, Admin write
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if _isAdminWriteAllowed();
    }

    // Notifications: user inbox documents are readable by owner only.
    // Writes are Cloud Functions-only via Admin SDK (rules deny client writes).
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /servicePersonnel/{personnelId}/notifications/{notificationId} {
      allow read: if isOwner(personnelId) || isAdmin();
      allow write: if false;
    }

    match /admin_role_users/{email} {
      allow read, write: if _isAdminWriteAllowed();
    }

    // Whitelisted Partners: Admins can read/write all entries.
    // Authenticated users may read their own entry to verify their whitelist status.
    // Document IDs are email addresses; comparison is case-insensitive.
    match /whitelisted_partners/{email} {
      allow read: if isAdmin()
        || (isAuthenticated()
            && request.auth.token.get('email', null) != null
            && request.auth.token.email.lower() == email.lower());
      allow write: if _isAdminWriteAllowed();
    }

    // Transactions: Only Cloud Functions write (via admin SDK bypass).
      // Only booking owners and admins can read transaction details.
    // This collection stores payment records and must never be written by the client.
    match /transactions/{transactionId} {
      allow read: if isVerified() && (
        // User can read their own transaction
        request.auth.uid == resource.data.userId ||
        // Admin can read all
        _isAdminWriteAllowed()
      );
      // All writes must come from Cloud Functions (admin SDK, bypasses rules)
      // Client cannot write directly
      allow write: if false;
    }

    // Immutable admin audit ledger: read-only for primary admins, never writable by clients.
    match /admin_audit_logs/{logId} {
      allow read: if _isPrimaryAdmin();
      allow write: if false;
    }

    // Catch-all: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
